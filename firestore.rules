rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collections ---

    // Config/Subjects
    match /config/subjects/list/{subjectId} {
      allow read: if true;
      allow create: if isSignedIn(); // Allow initial seeding
      allow write: if isAdmin(); 
    }

    // Students
    match /students/{studentId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidStudent(incoming()) && isValidId(studentId);
      allow update: if (isSignedIn() && isValidStudent(incoming())) && (
        isAdmin() || 
        incoming().diff(existing()).affectedKeys().hasOnly(['scores'])
      );
      allow delete: if isAdmin();
    }

    function isAdmin() {
      return isSignedIn() && !request.auth.token.is_anonymous && (
        request.auth.token.email == "ronnyyoon0922@gmail.com" ||
        request.auth.token.email_verified == true && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidStudent(data) {
      return data.id is string && data.id.size() <= 10 &&
             data.name is string && data.name.size() <= 20 &&
             data.scores is map;
    }

    // Historical Data
    match /historical_data/{studentId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidHistorical(incoming()) && isValidId(studentId);
      allow update: if isSignedIn() && isValidHistorical(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['1-1-5', '1-1-9', '1-2-5', '1-2-9'])
      );
    }

    function isValidHistorical(data) {
      return (data.get('1-1-5', 0) is number) &&
             (data.get('1-1-9', 0) is number) &&
             (data.get('1-2-5', 0) is number) &&
             (data.get('1-2-9', 0) is number);
    }

    match /college_admissions/{admissionId} {
      allow read: if true;
      allow create: if isSignedIn(); 
      allow write: if isAdmin();
    }
  }
}
